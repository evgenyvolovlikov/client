{
	"useTabs": true,
	"tabWidth": 4,
	"bracketSpacing": false,
	"printWidth": 96,
	"semi": true,
	"singleQuote": true,
	"trailingComma": "all",
	"arrowParens": "always",
	"htmlWhitespaceSensitivity": "ignore",
	"endOfLine": "lf",
	"bracketSameLine": false,
	"singleAttributePerLine": true,

	"plugins": ["@trivago/prettier-plugin-sort-imports"],
	"importOrderParserPlugins": ["typescript", "decorators-legacy"],
	"importOrder": [
		"^@angular/(.*)$",
		"<THIRD_PARTY_MODULES>",
		"^@app/(.*)$",
		"^@pages/(.*)$",
		"^@widgets/(.*)$",
		"^@features/(.*)$",
		"^@entities/(.*)$",
		"^@shared/(.*)$",
		"^[./]"
	],
	"importOrderSeparation": true,
	"importOrderSortSpecifiers": true,

	"overrides": [
		{
			"files": ["*.component.html"],
			"options": {
				"useTabs": false,
				"tabWidth": 2,
				"parser": "angular"
			}
		},

		{
			"files": ["*.html"],
			"options": {
				"useTabs": false,
				"tabWidth": 2
			}
		},

		{
			"files": ["*.json", "*.md", "*.yaml", "*.yml"],
			"options": {
				"useTabs": false,
				"tabWidth": 2
			}
		}
	]
}
